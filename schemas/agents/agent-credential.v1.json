{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.sovrn.place/agent/v1/agent-credential.json",
  "title": "SovrnAgentCredential",
  "description": "W3C VC 2.0 credential type for agent identity, capabilities, and delegation in the Sovrn protocol. Play Mode schema (open, Apache 2.0).",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "status": "DRAFT",
  "type": "object",
  "required": ["@context", "id", "type", "issuer", "validFrom", "credentialSubject"],
  "properties": {
    "@context": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "contains": { "const": "https://www.w3.org/ns/credentials/v2" },
      "description": "JSON-LD contexts. Must include W3C VC 2.0 context and Sovrn agent context."
    },
    "id": {
      "type": "string",
      "format": "uri",
      "description": "Unique credential identifier (URN UUID recommended)"
    },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "VerifiableCredential" },
      "description": "Must include VerifiableCredential and SovrnAgentCredential"
    },
    "issuer": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "DID of the issuing authority (zone authority, platform, or self)"
        },
        "name": {
          "type": "string",
          "description": "Human-readable issuer name"
        }
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time",
      "description": "Credential validity start (ISO 8601)"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time",
      "description": "Credential validity end (ISO 8601)"
    },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "principalDID", "issuanceMethod"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Agent DID (did:sovrn:agent:{uuid} or other DID method)"
        },
        "agentType": {
          "type": "string",
          "enum": ["AUTONOMOUS", "SUPERVISED", "DELEGATED"],
          "description": "Agent operational mode. OPTIONAL per Layer 1 D1 (not a trust signal)."
        },
        "principalDID": {
          "type": "string",
          "description": "DID of the human principal who controls this agent"
        },
        "principalType": {
          "type": "string",
          "enum": ["NATURAL", "LEGAL"],
          "description": "Principal class. Default NATURAL per Layer 1 D2."
        },
        "principalSiName": {
          "type": "string",
          "description": "Human principal's .si name (optional)"
        },
        "issuanceMethod": {
          "type": "string",
          "enum": ["SELF_ATTESTED", "COMMUNITY_ATTESTED", "ZONE_ISSUED", "ORACLE_ISSUED"],
          "description": "How this credential was issued. SELF_ATTESTED provides identity only, not trust. ZONE_ISSUED carries authority attestation."
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["action"],
            "properties": {
              "action": {
                "type": "string",
                "description": "Capability action identifier"
              },
              "jurisdictions": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Zone federation IDs where this capability is valid. '*' for all zones."
              },
              "constraints": {
                "type": "object",
                "additionalProperties": true,
                "description": "Action-specific constraints (max values, approval thresholds, etc.)"
              }
            }
          },
          "description": "Agent capabilities with jurisdictional scope"
        },
        "verificationStatus": {
          "type": "object",
          "properties": {
            "principalKYC": {
              "type": "boolean",
              "description": "Whether the principal has completed identity verification"
            },
            "principalKYCTier": {
              "type": "integer",
              "description": "Principal's KYC tier level"
            },
            "agentCodeAudit": {
              "type": "boolean",
              "description": "Whether the agent code has been audited"
            },
            "agentBehaviorStatus": {
              "type": "string",
              "description": "Agent behavior assessment result (implementation-defined values)"
            }
          }
        },
        "credentialHash": {
          "type": "string",
          "pattern": "^(sha256|sha3-256|shake256):[a-f0-9]{64,128}$",
          "description": "Cryptographic hash of the credential content for integrity verification. Algorithm prefix provides agility."
        }
      }
    },
    "credentialStatus": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "type": { "type": "string" },
        "statusPurpose": {
          "type": "string",
          "enum": ["revocation", "suspension"]
        },
        "statusListIndex": { "type": "string" },
        "statusListCredential": { "type": "string", "format": "uri" }
      },
      "description": "W3C BitstringStatusListEntry for revocation/suspension"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "id": { "type": "string", "format": "uri" },
          "type": {
            "type": "string",
            "description": "Evidence type identifier. Common types: UCANDelegation, KYCAttestation. Implementers may define additional types."
          }
        },
        "additionalProperties": true
      },
      "description": "Supporting evidence (delegation tokens, KYC attestations, audit results)"
    },
    "proof": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "description": "A single W3C Data Integrity proof (or SD-JWT/COSE external proof). Index 0 is the issuer proof; indices 1+ are co-signer proofs (Layer 1 D3). Verifiers check every entry."
      },
      "description": "Array of proofs (multi-proof co-signing, Layer 1 D3)"
    }
  }
}
