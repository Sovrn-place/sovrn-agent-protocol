{
  "name": "@sovrn-place/agent-protocol-mcp-server-reference",
  "version": "0.1.0",
  "description": "Sovrn Agent Protocol - MCP server reference implementation. Stateless verifier for Layers 0-2 (discovery, credentials, delegation) over MCP transport. Public build-from-design reference; distinct from any Sovrn-operated managed server.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start:stdio": "tsx src/index.ts --transport stdio",
    "start:http": "tsx src/index.ts --transport http",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:conformance": "tsc --noEmit -p tsconfig.conformance.json",
    "test": "tsx --test tests/*.test.ts",
    "conformance": "tsx conformance/run.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sd-jwt/crypto-nodejs": "^0.19.0",
    "@sd-jwt/sd-jwt-vc": "^0.20.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "jose": "^6.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
